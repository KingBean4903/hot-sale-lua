{
	"compilerOptions": {
		"target": "ES2023",
		"module": "ESNext",
		"lib" : ["es2022", "dom"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"baseUrl" : "./",
	},
 "include": ["src/**/*"],
 "exclude": ["node_modules", "dist"]
}
