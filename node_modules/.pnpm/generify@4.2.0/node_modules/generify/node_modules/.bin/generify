#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/generify@4.2.0/node_modules/generify/node_modules:/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/generify@4.2.0/node_modules:/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/generify@4.2.0/node_modules/generify/node_modules:/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/generify@4.2.0/node_modules:/home/baimungi/Documents/node_2025/portfolio/hot_path/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../generify.js" "$@"
else
  exec node  "$basedir/../../generify.js" "$@"
fi
